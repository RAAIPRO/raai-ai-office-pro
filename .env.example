# AI-офис PRO v3.4 — опциональные переменные окружения
#
# Без этого файла работают 7 из 9 режимов (только на промпте).
# Заполните только если хотите чтобы бот читал реальные данные из Ваших систем.
#
# Как использовать:
# cp .env.example .env
# # откройте .env и заполните нужные ключи
#
# Удалите или закомментируйте неиспользуемые строки. # ═══════════════════════════════════════════════════
# Google Sheets — для брифинга и Weekly Review по цифрам
# ═══════════════════════════════════════════════════
# Где брать: https://console.cloud.google.com/ → Service Account → JSON key
# Гайд: docs/onboarding.md раздел "Google Sheets" GOOGLE_SHEETS_CREDENTIALS_JSON="" # путь к JSON-ключу сервис-аккаунта
GOOGLE_SHEETS_SPREADSHEET_ID="" # ID таблицы (из URL)
GOOGLE_SHEETS_TAB_REVENUE="Revenue" # название вкладки с выручкой
GOOGLE_SHEETS_TAB_TASKS="Tasks" # название вкладки с задачами (OKR KR прогресс) # ═══════════════════════════════════════════════════
# Google Calendar — для режимов 2 (брифинг) и 7 (делегирование)
# ═══════════════════════════════════════════════════ GOOGLE_CALENDAR_ID="" # ID календаря (обычно ваш email) # ═══════════════════════════════════════════════════
# Telegram — отправка брифингов/напоминаний в личку
# ═══════════════════════════════════════════════════
# Где брать бот-токен: @BotFather в Telegram → /newbot
# Где брать chat_id: @userinfobot → переслать боту любое сообщение TELEGRAM_BOT_TOKEN="" # токен вашего бота
TELEGRAM_CHAT_ID="" # ваш chat_id # ═══════════════════════════════════════════════════
# Web Search (опционально) — для ставки ЦБ / внешних данных
# ═══════════════════════════════════════════════════ EXA_API_KEY="" # Exa.ai для поиска (опционально)
TAVILY_API_KEY="" # Tavily (альтернатива) # ═══════════════════════════════════════════════════
# Модель LLM (если работает вне Claude/OpenClaw)
# ═══════════════════════════════════════════════════ ANTHROPIC_API_KEY="" # если запускаете через Anthropic SDK
OPENAI_API_KEY="" # если через OpenAI-совместимый API (DeepSeek)
DEEPSEEK_API_KEY="" # если прямо DeepSeek
